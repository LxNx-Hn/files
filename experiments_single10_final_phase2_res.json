{
  "_comment": [
    "최종 2차 런",
    "10개 장르 단일장르 + 균형 샘플링",
    "RES early/late/joint + RES image_only",
    "2 GPU 기준"
  ],

  "gpus": [0, 1],
  "max_per_gpu": 1,
  "results_dir": "./results_single10_final_phase2_res",

  "common_args": {
    "data_dir": "./data_variants/single10_balanced",
    "n_classes": 10,
    "epochs": 50,
    "batch_size": 32,
    "lr": 0.001,
    "img_lr": 0.0005,
    "txt_lr": 0.00002,
    "fusion_lr": 0.001,
    "weight_decay": 0.0001,
    "warmup_epochs": 5,
    "feat_dim": 256,
    "dropout": 0.4,
    "max_text_len": 96,
    "save_models": false
  },

  "experiments": [
    {
      "id": 0,
      "name": "RES+transformer+early+freeze_off",
      "img_encoder": "res",
      "txt_encoder": "transformer",
      "fusion": "early",
      "cnn_layers": 4,
      "freeze_bert": false,
      "estimated_minutes": 15
    },
    {
      "id": 1,
      "name": "RES+transformer+late+freeze_off",
      "img_encoder": "res",
      "txt_encoder": "transformer",
      "fusion": "late",
      "cnn_layers": 4,
      "freeze_bert": false,
      "estimated_minutes": 15
    },
    {
      "id": 2,
      "name": "RES+transformer+joint+freeze_off",
      "img_encoder": "res",
      "txt_encoder": "transformer",
      "fusion": "cross_attention",
      "cnn_layers": 4,
      "freeze_bert": false,
      "estimated_minutes": 17
    },
    {
      "id": 3,
      "name": "RES+transformer+image_only",
      "img_encoder": "res",
      "txt_encoder": "transformer",
      "fusion": "image_only",
      "cnn_layers": 4,
      "freeze_bert": true,
      "estimated_minutes": 9
    }
  ]
}
